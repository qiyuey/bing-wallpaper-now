{
  "name": "bing-wallpaper-now",
  "private": true,
  "version": "1.5.6",
  "type": "module",
  "engines": {
    "node": ">=26"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "check": "pnpm run check:rust && pnpm run check:frontend && pnpm run lint:md",
    "check:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml -- --check && cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings && cargo test --manifest-path src-tauri/Cargo.toml",
    "check:frontend": "pnpm run typecheck && pnpm run lint && pnpm run format:check && pnpm run test:frontend",
    "fix": "cargo fmt --manifest-path src-tauri/Cargo.toml && pnpm run lint:fix && pnpm run format && pnpm run lint:md:fix",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src scripts/run-bash.mjs",
    "lint:fix": "oxlint src scripts/run-bash.mjs --fix",
    "lint:md": "markdownlint \"*.md\" \"docs/**/*.md\" --ignore node_modules --ignore src-tauri/target",
    "lint:md:fix": "markdownlint \"*.md\" \"docs/**/*.md\" --ignore node_modules --ignore src-tauri/target --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"scripts/run-bash.mjs\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"scripts/run-bash.mjs\"",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test:frontend": "vitest run",
    "test:e2e:web": "playwright test",
    "test:e2e:web:headed": "playwright test --headed",
    "test:e2e:web:install": "playwright install chromium",
    "test": "cargo test --manifest-path src-tauri/Cargo.toml && vitest run",
    "package": "tauri build",
    "version:patch": "node scripts/run-bash.mjs scripts/manage-version.sh patch",
    "version:minor": "node scripts/run-bash.mjs scripts/manage-version.sh minor",
    "version:major": "node scripts/run-bash.mjs scripts/manage-version.sh major",
    "release": "node scripts/run-bash.mjs scripts/manage-version.sh release",
    "retag": "node scripts/run-bash.mjs scripts/manage-version.sh retag",
    "icons": "node scripts/generate-icons.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-window": "^2.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^29.1.1",
    "markdownlint-cli": "^0.49.0",
    "oxlint": "^1.73.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.9.4",
    "typescript": "^7.0.2",
    "vite": "8.1.3",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@11.10.0"
}
